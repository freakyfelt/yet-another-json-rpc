{
  "name": "@freakyfelt/yarpc-cli",
  "version": "2.0.1",
  "description": "Yet Another JSON RPC CLI",
  "keywords": [],
  "author": {
    "name": "Bruce Felt",
    "url": "https://github.com/freakyfelt/yet-another-json-rpc"
  },
  "contributors": [],
  "homepage": "https://github.com/freakyfelt/yet-another-json-rpc",
  "bugs": "https://github.com/freakyfelt/yet-another-json-rpc/issues",
  "repository": {
    "url": "https://github.com/freakyfelt/yet-another-json-rpc"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.17.0"
  },
  "type": "module",
  "bin": {
    "yarpc-cli": "./dist/bin/yarpc-cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:check": "tsdown --publint --attw",
    "prepublishOnly": "npm run build",
    "build:examples": "npm run build:examples:yaml && npm run build:examples:json",
    "build:examples:yaml": "node ./dist/bin/yarpc-cli.mjs -i examples/widgets.rpc.yaml -o examples/widgets.oas.yaml -f yaml",
    "build:examples:json": "node ./dist/bin/yarpc-cli.mjs -i examples/widgets.rpc.yaml -o examples/widgets.oas.json -f json",
    "ci": "npm run lint:check && npm run test:node && npm run format:check && npm run build:check",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:code",
    "lint:code": "eslint . --cache --fix --ext .ts",
    "lint:check": "eslint . --cache --ext .ts && tsc --noEmit",
    "pretest": "npm run lint && tsc --noEmit",
    "test": "npm run test:node",
    "test:node": "npm run test:only -- src/**/*.test.ts",
    "test:only": "tsx --test",
    "posttest": "npm run format && npm run build:examples"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@eslint/js": "^10.0.1",
    "@sinclair/typebox": "^0.34.49",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "publint": "^0.3.18",
    "tsx": "^4.20.6",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix"
  },
  "dependencies": {
    "just-safe-get": "^4.2.0",
    "just-intersect": "^4.3.0",
    "openapi3-ts": "^4.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.3"
  }
}
